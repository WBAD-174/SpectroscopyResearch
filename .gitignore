# 数据（保留目录结构，不传数据本身）
data/*
!data/.gitkeep
*.csv
*.xlsx
*.npy
*.npz
*.pkl

# 结果（同上）
results/*
!results/.gitkeep

# 模型权重
*.pt
*.pth
*.ckpt

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Jupyter
.ipynb_checkpoints/

# 密钥
.env

# 测试缓存
.pytest_cache/
.mypy_cache/
.ruff_cache/

# 编辑器 / 系统
.vscode/
.idea/
*.swp
.DS_Store

# 临时
*.log
tmp/